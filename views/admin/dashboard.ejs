                                   @select="onChanged()"
                                   class="menu__modifier-input menu__modifier-date-till display__date"/>

                <div class="display__days">

                    <label v-for="(day, i) in modifier.days"
                           class="display__day-wrap"
                           :key="i">

                        <input type="checkbox"
                               @change="onChanged()"
                               v-model="day.active">

                        <span class="display__day-name">{{getDayName(i)}}</span>

                        <input class="menu__modifier-input display__day"
                               :value="day.begin"
                               v-imask="mask"
